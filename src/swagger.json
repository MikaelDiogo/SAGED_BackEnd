{
  "openapi": "3.0.3",
  "info": {
    "title": "SAGED API",
    "description": "Backend do Sistema de Acompanhamento e Gestão de Demandas (SAGED): protocolo inteligente `YYYY-DEP-TEC-ID`, RBAC por secretaria/técnico, histórico auditável e integração WhatsApp (resumo por LID).\n\n**Papéis (`role`)**: `ADMIN_GERAL` (visão global), `ADMIN_SETOR` e `TECNICO_LIDER` (fila da secretaria), `TECNICO` (quadro pessoal). Um `TECNICO` pode ser promovido com `is_sector_leader=true` para mesma visão de líder.\n\n**Autenticação**: rotas privadas utilizam um **Cookie HttpOnly** chamado `token`, emitido automaticamente no `POST /sessions`. O navegador gerencia o envio deste cookie em todas as requisições subsequentes.",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "http://localhost:3333",
      "description": "Desenvolvimento local"
    }
  ],
  "tags": [
    { "name": "Autenticação", "description": "Login JWT" },
    { "name": "Usuários", "description": "Cadastro e perfis (RBAC + especialidade TEC)" },
    { "name": "Departamentos", "description": "Secretarias e códigos DEP do protocolo" },
    { "name": "Especialidades", "description": "Especialidades técnicas dos operadores (ex.: HARDWARE, REDES)" },
    { "name": "Demandas", "description": "Ciclo de vida do chamado e histórico" },
    { "name": "Relatórios", "description": "Indicadores gerenciais e exportação PDF" },
    { "name": "Integrações", "description": "Endpoints para bots protegidos por API Key" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Chave de serviço estática para integrações de backend/bots."
      }
    },
    "schemas": {
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "admin@prefeitura.gov" },
          "password": { "type": "string", "format": "password", "example": "suaSenhaSegura" }
        }
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/UserPublic" }
        }
      },
      "UserPublic": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "$ref": "#/components/schemas/UserRole" },
          "tech_type_code": {
            "type": "string",
            "nullable": true,
            "description": "Código TEC da especialidade (ex.: 01 Hardware, 02 Redes).",
            "example": "01"
          },
          "is_sector_leader": {
            "type": "boolean",
            "description": "Quando true em um TECNICO, amplia a visão para toda a secretaria.",
            "example": false
          },
          "departmentId": { "type": "string", "format": "uuid", "nullable": true }
        }
      },
      "UserRole": {
        "type": "string",
        "enum": ["ADMIN_GERAL", "ADMIN_SETOR", "TECNICO_LIDER", "TECNICO"],
        "example": "TECNICO"
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["name", "email", "password", "role"],
        "properties": {
          "name": { "type": "string", "example": "Maria Souza" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" },
          "role": { "$ref": "#/components/schemas/UserRole" },
          "tech_type_code": { "type": "string", "nullable": true, "example": "01" },
          "is_sector_leader": { "type": "boolean", "default": false },
          "departmentId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "Obrigatório para todos os papéis exceto `ADMIN_GERAL`."
          }
        }
      },
      "CreateDepartmentRequest": {
        "type": "object",
        "required": ["name", "code"],
        "properties": {
          "name": { "type": "string", "example": "Secretaria Municipal de Saúde" },
          "code": {
            "type": "string",
            "description": "Código DEP usado no protocolo.",
            "example": "01"
          }
        }
      },
      "Department": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "CreateSpecialtyRequest": {
        "type": "object",
        "required": ["code", "name"],
        "properties": {
          "code": { "type": "string", "example": "01", "description": "Código identificador de 2 dígitos." },
          "name": { "type": "string", "example": "HARDWARE" }
        }
      },
      "Specialty": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "DemandStatus": {
        "type": "string",
        "enum": ["A_FAZER", "EM_ANDAMENTO", "CONCLUIDO", "INTERROMPIDO", "CANCELADO"]
      },
      "CreateDemandRequest": {
        "type": "object",
        "required": ["title", "description", "senderId", "departmentId", "techTypeCode"],
        "properties": {
          "title": { "type": "string", "example": "Switch do posto com falha intermitente" },
          "description": { "type": "string", "example": "Equipamento reinicia sozinho à noite." },
          "senderId": { "type": "string", "format": "uuid" },
          "departmentId": { "type": "string", "format": "uuid" },
          "techTypeCode": { "type": "string", "description": "Código TEC do segmento.", "example": "02" },
          "asset_tag": { "type": "string", "nullable": true, "example": "123456" }
        }
      },
      "Demand": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "protocol": { "type": "string", "example": "2026-01-02-00005" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "$ref": "#/components/schemas/DemandStatus" },
          "viewed": { "type": "boolean" },
          "asset_tag": { "type": "string", "nullable": true },
          "deptCode": { "type": "string" },
          "techTypeCode": { "type": "string" },
          "senderId": { "type": "string", "format": "uuid" },
          "current_technician_id": { "type": "string", "format": "uuid", "nullable": true },
          "departmentId": { "type": "string", "format": "uuid" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "UpdateDemandStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "$ref": "#/components/schemas/DemandStatus" },
          "description": { "type": "string", "description": "Mínimo 15 caracteres se for cancelado ou interrompido." },
          "asset_tag": { "type": "string", "nullable": true }
        }
      },
      "DemandHistoryEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "demandId": { "type": "string", "format": "uuid" },
          "technicianId": { "type": "string", "format": "uuid" },
          "previous_status": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/DemandStatus" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ManagementReport": {
        "type": "object",
        "properties": {
          "period": { "type": "string", "example": "5/2026" },
          "scope": { "type": "string" },
          "metrics": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "resolutionRate": { "type": "string" },
              "avgTime": { "type": "string" },
              "interrupted": { "type": "integer" }
            }
          },
          "statusCounts": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          },
          "technicians": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "count": { "type": "integer" },
                "concluded": { "type": "integer" }
              }
            }
          }
        }
      },
      "WhatsAppSummaryResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "description": "Texto formatado para envio ao WhatsApp." }
        }
      }
    }
  },
  "paths": {
    "/sessions": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login do sistema",
        "description": "Gera sessão e injeta Cookie HttpOnly 'token' de segurança.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Cookie definido e dados retornados.",
            "headers": {
              "Set-Cookie": {
                "description": "Contém o token JWT com flags HttpOnly; Secure; SameSite=Lax",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SessionResponse" } }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorMessage" } } }
          }
        }
      }
    },
    "/users": {
      "post": {
        "tags": ["Usuários"],
        "summary": "Criar novo usuário",
        "description": "Apenas ADMIN_GERAL pode criar contas de operadores.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateUserRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Criado com sucesso",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserPublic" } } }
          },
          "400": {
            "description": "Erro de processamento",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorMessage" } } }
          }
        }
      }
    },
    "/departments": {
      "post": {
        "tags": ["Departamentos"],
        "summary": "Cadastrar secretaria municipal",
        "description": "Apenas ADMIN_GERAL possui permissão.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateDepartmentRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Criado",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Department" } } }
          }
        }
      },
      "get": {
        "tags": ["Departamentos"],
        "summary": "Listar todas as secretarias",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista recuperada",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Department" } } }
            }
          }
        }
      }
    },
    "/specialties": {
      "post": {
        "tags": ["Especialidades"],
        "summary": "Criar nova especialidade técnica",
        "description": "Apenas ADMIN_GERAL pode registrar novas especialidades.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateSpecialtyRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Especialidade criada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Specialty" } } }
          }
        }
      },
      "get": {
        "tags": ["Especialidades"],
        "summary": "Listar especialidades ativas",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de especialidades",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Specialty" } } }
            }
          }
        }
      }
    },
    "/demands": {
      "get": {
        "tags": ["Demandas"],
        "summary": "Listar chamados com escopo contextual",
        "description": "Aplica o RBAC automaticamente no banco de dados.",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 }, "description": "Página atual." },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 10 }, "description": "Itens por página." }
        ],
        "responses": {
          "200": {
            "description": "Registros retornados com paginação",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Demand" } } }
            }
          }
        }
      },
      "post": {
        "tags": ["Demandas"],
        "summary": "Abrir nova demanda",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateDemandRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Demanda criada com protocolo gerado",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Demand" } } }
          }
        }
      }
    },
    "/demands/{id}/status": {
      "patch": {
        "tags": ["Demandas"],
        "summary": "Alterar estágio da demanda",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateDemandStatusRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Movimentação registrada",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } }
          }
        }
      }
    },
    "/demands/{id}/history": {
      "get": {
        "tags": ["Demandas"],
        "summary": "Visualizar linha do tempo de auditoria",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Histórico sequencial",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DemandHistoryEntry" } } }
            }
          }
        }
      }
    },
    "/demands/reports/management": {
      "get": {
        "tags": ["Relatórios"],
        "summary": "Obter indicadores do painel analítico",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "month", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 12 } },
          { "name": "year", "in": "query", "schema": { "type": "integer" } },
          { "name": "departmentId", "in": "query", "schema": { "type": "string", "format": "uuid" }, "description": "Filtro livre apenas para ADMIN_GERAL." }
        ],
        "responses": {
          "200": {
            "description": "JSON de métricas para gráficos",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ManagementReport" } } }
          }
        }
      }
    },
    "/demands/reports/export-pdf": {
      "get": {
        "tags": ["Relatórios"],
        "summary": "Baixar documento impresso consolidado",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "month", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 12 } },
          { "name": "year", "in": "query", "schema": { "type": "integer" } },
          { "name": "departmentId", "in": "query", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Documento gerado",
            "content": { "application/pdf": { "schema": { "type": "string", "format": "binary" } } }
          }
        }
      }
    },
    "/demands/whatsapp/summary/{lid}": {
      "get": {
        "tags": ["Integrações"],
        "summary": "Relatório sintético para bot externo",
        "description": "Protegido estritamente pelo middleware de x-api-key do SAGE.",
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          { "name": "lid", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Identificador único de chat." }
        ],
        "responses": {
          "200": {
            "description": "Mensagem texturizada em formato string",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WhatsAppSummaryResponse" } } }
          }
        }
      }
    }
  }
}